# ──────────────────────────────────────────────────────────────────────────────
# Keep the build context tiny. data/ is 3.4 GB and is NOT needed by the
# dashboard in mock-data mode — never ship it into the image.
# ──────────────────────────────────────────────────────────────────────────────

# Heavy geospatial data & rasters
data/
*.tif
*.tiff
*.img
*.vrt
*.nc
*.zip
*.tar.gz
*.gz
*.SAFE/

# Virtual environments
.venv/
.venv-*/
venv/
env/
ENV/

# Git & CI
.git/
.gitignore
.github/

# Python caches / build
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Tests & dev-only material (not needed at runtime)
tests/

# Secrets — never bake into an image
.env

# Docs & stray outputs
*.md
*.out.txt
CUsers*.txt
C:Users*

# OS / IDE
.DS_Store
Thumbs.db
.idea/
*.swp

# ── Exceptions: ship the small curated PNSG outputs the dashboard needs ────────
# data/ is excluded above; these specific files are tiny and required at runtime
# for the "Sendas reales (satélite)" tab and the official park boundary.
!data/outputs/pnsg/pipeline_a_results.geojson
!data/outputs/pnsg/pipeline_a_summary.json
!data/raw_assets/vector_data/oapn/oapn_limite_pn.geojson
