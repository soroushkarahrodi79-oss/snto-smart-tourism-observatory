# ============================================================
# SNTO — Smart Natural Tourism Observatory
# Plantilla de variables de entorno
# Copia este archivo como .env y rellena tus valores reales.
# ============================================================

# ── PostgreSQL / PostGIS ─────────────────────────────────────
SNTO_DB_HOST=localhost
SNTO_DB_PORT=5432
SNTO_DB_NAME=snto
SNTO_DB_USER=postgres
SNTO_DB_PASS=TU_CONTRASEÑA_AQUI

# ── Modos de operación ───────────────────────────────────────
USE_MOCK_DATA=true

# ── Google Earth Engine (solo si USE_MOCK_DATA=false) ────────
GEE_PROJECT_ID=
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=

# ── API server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
