# ============================================================
# SNTO — Smart Natural Tourism Observatory
# Plantilla de variables de entorno
# Copia este archivo como .env y rellena tus valores reales.
# ============================================================

# ── PostgreSQL / PostGIS ─────────────────────────────────────
SNTO_DB_HOST=localhost
SNTO_DB_PORT=5432
SNTO_DB_NAME=snto
SNTO_DB_USER=postgres
SNTO_DB_PASS=TU_CONTRASEÑA_AQUI

# ── Modos de operación ───────────────────────────────────────
USE_MOCK_DATA=true

# ── Auth mínima de escritura /api/v2 (Fase 5.8, ADR-011) ─────
# Vacío/ausente = auth desactivada (escrituras abiertas, dev local).
# Con valor = toda escritura /api/v2 exige la cabecera X-API-Key; la
# lectura nunca se gatea.
SNTO_API_KEY=

# ── Google Earth Engine (solo si USE_MOCK_DATA=false) ────────
GEE_PROJECT_ID=
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=

# ── API server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── Telemetría de uso de vistas (opt-in, 100% local) ─────────
# Si se activa (=1), el dashboard registra qué vista/audiencia se usa en un
# JSONL local bajo data/ (git-ignored). Sin PII, sin red: solo (timestamp, vista).
# Sirve para priorizar dónde profundizar el detalle. Desactivada por defecto.
SNTO_TELEMETRY=0
